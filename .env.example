# =============================================================
# Idealize 360º — Variáveis de ambiente
# Copie este arquivo para ".env" e preencha com os dados do seu
# projeto Supabase (Project Settings > API).
#
# IMPORTANTE: use APENAS a chave "anon public". NUNCA coloque a
# chave "service_role" aqui — ela é secreta e não pode ir para o
# frontend.
# =============================================================

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
